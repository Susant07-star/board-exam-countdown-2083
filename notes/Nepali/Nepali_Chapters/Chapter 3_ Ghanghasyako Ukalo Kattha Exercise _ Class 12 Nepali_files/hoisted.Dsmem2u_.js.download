document.addEventListener("DOMContentLoaded",function(){const c=document.getElementById("mobile-menu"),o=document.getElementById("sidebar"),i=document.getElementById("sidebar-close"),s=document.getElementById("sidebar-overlay"),d=document.body;function a(){o?.classList.add("active"),s?.classList.add("active"),c?.classList.add("active"),d.classList.add("sidebar-open")}function t(){o?.classList.remove("active"),s?.classList.remove("active"),c?.classList.remove("active"),d.classList.remove("sidebar-open")}function l(e){const n=e.classList.contains("active");document.querySelectorAll(".mobile-dropdown").forEach(r=>r.classList.remove("active")),n||e.classList.add("active")}c?.addEventListener("click",a),i?.addEventListener("click",t),s?.addEventListener("click",t),document.querySelectorAll(".mobile-dropdown-btn").forEach(e=>{e.addEventListener("click",function(){const n=this.closest(".mobile-dropdown");l(n)})}),document.querySelectorAll(".sidebar-menu a").forEach(e=>{e.addEventListener("click",t)}),document.addEventListener("keydown",function(e){e.key==="Escape"&&t()})});
